              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Admin Create Mcp Server Version",
        "tags": [
          "admin-mcp"
        ]
      }
    },
