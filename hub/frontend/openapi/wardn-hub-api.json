            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistryServerVersionDetailResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Conflict"
          },
          "422": {
